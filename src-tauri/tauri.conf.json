{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeus",
  "version": "0.1.0",
  "identifier": "com.benclawbot.zeus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zeus",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../skills/": "skills"
    },
    "shortDescription": "Local-first coding agent",
    "longDescription": "Zeus is a local-first coding agent with visible harness evolution and MiniMax M3 provider support."
  }
}
