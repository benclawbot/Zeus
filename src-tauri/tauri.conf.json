{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeus",
  "version": "0.1.0",
  "identifier": "com.benclawbot.zeus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zeus",
        "fullscreen": false,
        "maximized": true,
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../skills/": "skills",
      "../scripts/zeus-browser-driver.mjs": "scripts/zeus-browser-driver.mjs"
    },
    "externalBin": [
      "binaries/ddgs"
    ],
    "shortDescription": "Local-first coding agent",
    "longDescription": "Zeus is a local-first coding agent with visible harness evolution and MiniMax M3 provider support."
  }
}
